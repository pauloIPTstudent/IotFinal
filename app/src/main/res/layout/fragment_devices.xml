<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:layout_marginTop="42dp"
    tools:context=".DevicesFragment">

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        app:cardCornerRadius="28dp"
        app:cardBackgroundColor="#F9FAFC"
        app:strokeWidth="0dp"
        app:cardElevation="4dp">

        <!-- Contentor principal do Card -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="#F9FAFC"
            android:padding="20dp">

            <!-- 1. Contentor do Ícone da Pulseira (Fundo Azul Claro Arredondado) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_icon_container"
                android:layout_width="48dp"
                android:layout_height="48dp"
                app:cardCornerRadius="14dp"
                app:cardBackgroundColor="#E8EAF6"
                app:strokeWidth="0dp"
                app:cardElevation="0dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent">

                <ImageView
                    android:id="@+id/img_device"
                    android:layout_width="30dp"
                    android:layout_height="29dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_smartwatch2"
                    app:tint="#1D2786"
                    tools:ignore="ContentDescription" />
            </com.google.android.material.card.MaterialCardView>

            <!-- 2. Nome do Dispositivo -->
            <TextView
                android:id="@+id/txt_device_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="16dp"
                android:text="Pulseira Vital Pro"
                android:textColor="#1D2786"
                android:textSize="18sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                app:layout_constraintBottom_toBottomOf="@id/card_icon_container"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/card_icon_container"
                app:layout_constraintTop_toTopOf="@id/card_icon_container" />

            <!-- 3. Caixa de Atualização Interna (Fundo Azul Acizentado Suave) -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/card_update_box"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:cardCornerRadius="20dp"
                app:cardBackgroundColor="#E8EBF5"
                app:strokeWidth="0dp"
                app:cardElevation="0dp"
                app:layout_constraintTop_toBottomOf="@id/card_icon_container"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:padding="20dp">

                    <!-- Ícone de Download / Atualização do Sistema -->
                    <ImageView
                        android:id="@+id/img_update_icon"
                        android:layout_width="32dp"
                        android:layout_height="32dp"
                        android:src="@android:drawable/stat_sys_download_done"
                        app:tint="#1D2786"
                        tools:ignore="ContentDescription" />

                    <!-- Texto de Alerta -->
                    <TextView
                        android:id="@+id/txt_update_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="10dp"
                        android:text="Nova atualização disponível"
                        android:textColor="#1D2786"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        android:gravity="center" />

                    <!-- Botão de Ação Rápida (Estilo Pílula) -->
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btn_update_now"
                        android:layout_width="match_parent"
                        android:layout_height="54dp"
                        android:layout_marginTop="16dp"
                        android:text="Atualizar Agora"
                        android:textColor="#FFFFFF"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:fontFamily="sans-serif-medium"
                        android:textAllCaps="false"
                        app:backgroundTint="#1D2786"
                        app:cornerRadius="100dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp" />

                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.google.android.material.card.MaterialCardView>
</FrameLayout>
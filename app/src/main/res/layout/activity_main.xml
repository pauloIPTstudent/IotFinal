<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".RedBottonFragment">

    <!-- Container do Fragment Ativo (Ocupa o ecrã todo menos a Bottom Bar) -->
    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/fragmentContainerView3"
        android:name="com.example.healthfalldetectionapp.RedBottonFragment"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/bottom_nav"
        android:background="#F9FAFC"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Barra de Navegação de 3 Abas Modernas (Início, Dispositivos, Histórico) -->
    <LinearLayout
        android:id="@+id/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:background="#F9FAFC"
        android:orientation="horizontal"
        android:gravity="center"
        android:elevation="12dp"
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- ABA 1: Início -->
        <LinearLayout
            android:id="@+id/layout_nav_home"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/img_nav_home"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_home"
                app:tint="#1D2786" />

            <TextView
                android:id="@+id/txt_nav_home"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Início"
                android:textSize="12sp"
                android:textColor="#1D2786"
                android:fontFamily="sans-serif-medium" />
        </LinearLayout>

        <!-- ABA 2: Dispositivos -->
        <LinearLayout
            android:id="@+id/layout_nav_devices"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/img_nav_devices"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_sensor"
                app:tint="#7A7A7A" />

            <TextView
                android:id="@+id/txt_nav_devices"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Dispositivos"
                android:textSize="12sp"
                android:textColor="#7A7A7A"
                android:fontFamily="sans-serif-medium" />
        </LinearLayout>

        <!-- ABA 3: Histórico -->
        <LinearLayout
            android:id="@+id/layout_nav_history"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:background="?android:attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:focusable="true">

            <ImageView
                android:id="@+id/img_nav_history"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_book"
                app:tint="#7A7A7A" />

            <TextView
                android:id="@+id/txt_nav_history"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Histórico"
                android:textSize="12sp"
                android:textColor="#7A7A7A"
                android:fontFamily="sans-serif-medium" />
        </LinearLayout>

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
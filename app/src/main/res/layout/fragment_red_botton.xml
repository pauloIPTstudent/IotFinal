<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".RedBottonFragment">

    <androidx.constraintlayout.widget.ConstraintLayout
        xmlns:android="http://schemas.android.com/apk/res/android"
        xmlns:app="http://schemas.android.com/apk/res-auto"
        xmlns:tools="http://schemas.android.com/tools"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#F9FAFC"
        android:layout_marginTop="42dp"
        android:paddingHorizontal="24dp"
        tools:context=".HomeFragment">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/popup_concect"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_rounded_card"
            android:padding="16dp"
            app:layout_constraintTop_toTopOf="parent">

            <!-- 1. Indicador de Estado (Pequeno círculo ou pílula cinzenta/verde) -->
            <View
                android:id="@+id/status_dot"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_status_dot_disconnected"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

            <!-- 2. Textos Informativos de Conexão -->
            <LinearLayout
                android:id="@+id/layout_text_container"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginStart="14dp"
                android:layout_marginEnd="12dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toEndOf="@id/status_dot"
                app:layout_constraintEnd_toStartOf="@id/btn_connect_device">

                <TextView
                    android:id="@+id/txt_connection_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Nenhum dispositivo\nconectado"
                    android:textColor="#1F2226"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:lineSpacingMultiplier="1.1"
                    android:fontFamily="sans-serif-medium" />

                <TextView
                    android:id="@+id/txt_connection_subtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Conecte sua pulseira para monitoramento"
                    android:textColor="#7A7A7A"
                    android:textSize="11sp"
                    android:fontFamily="sans-serif" />
            </LinearLayout>

            <!-- 3. Botão de Ação Rápida "Conectar" -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_connect_device"
                android:layout_width="wrap_content"
                android:layout_height="40dp"
                android:text="Conectar"
                android:textColor="#FFFFFF"
                android:textSize="13sp"
                android:textStyle="bold"
                android:textAllCaps="false"
                app:backgroundTint="#1D2786"
                app:cornerRadius="100dp"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- BOTÃO PRINCIPAL: Pedir Ajuda (Circular com Sombra) -->
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/btn_pedir_ajuda"
            android:layout_width="260dp"
            android:layout_height="260dp"
            android:background="@drawable/bg_red_circle"
            android:elevation="12dp"
            android:clickable="true"
            android:focusable="true"
            android:foreground="?android:attr/selectableItemBackgroundBorderless"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@id/txt_instrucao"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintVertical_chainStyle="packed">

            <!-- Ícone do Asterisco / Estrela Médica -->
            <ImageView
                android:id="@+id/img_star"
                android:layout_width="64dp"
                android:layout_height="64dp"
                android:layout_marginBottom="12dp"
                android:src="@drawable/ic_warnning"
                app:tint="#FFFFFF"
                app:layout_constraintBottom_toTopOf="@id/txt_pedir_ajuda"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_chainStyle="packed" />

            <!-- Texto Central -->
            <TextView
                android:id="@+id/txt_pedir_ajuda"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PEDIR AJUDA"
                android:textColor="#FFFFFF"
                android:textSize="18sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-medium"
                android:letterSpacing="0.05"
                app:layout_constraintTop_toBottomOf="@id/img_star"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- Texto de Instrução Inferior -->
        <TextView
            android:id="@+id/txt_instrucao"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:layout_marginStart="24dp"
            android:layout_marginEnd="24dp"
            android:text="Mantenha o botão pressionado para emergências médicas ou de segurança."
            android:textColor="#5C6066"
            android:textSize="15sp"
            android:gravity="center"
            android:lineSpacingMultiplier="1.2"
            app:layout_constraintTop_toBottomOf="@id/btn_pedir_ajuda"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />



    </androidx.constraintlayout.widget.ConstraintLayout></FrameLayout>
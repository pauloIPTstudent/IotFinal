<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet"
    android:paddingBottom="24dp">

    <!-- 1. Barra superior de arrasto (Drag Handle) -->
    <View
        android:id="@+id/drag_handle"
        android:layout_width="48dp"
        android:layout_height="5dp"
        android:layout_marginTop="12dp"
        android:background="#D1D5DB"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 2. Título Centralizado -->
    <TextView
        android:id="@+id/txt_sheet_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:text="Procurando Dispositivos"
        android:textColor="#1F2226"
        android:textSize="20sp"
        android:textStyle="bold"
        android:fontFamily="sans-serif-medium"
        app:layout_constraintTop_toBottomOf="@id/drag_handle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 3. Indicador de Progresso (Scanning...) -->
    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/scan_progress"
        android:layout_width="120dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:indeterminate="true"
        app:indicatorColor="#1D2786"
        app:trackColor="#E2E8F0"
        app:layout_constraintTop_toBottomOf="@id/txt_sheet_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 4. Contentor da Lista (Simulado para visualização rápida no Android Studio) -->
    <LinearLayout
        android:id="@+id/layout_device_list"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:orientation="vertical"
        app:layout_constraintTop_toBottomOf="@id/scan_progress"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">


    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>